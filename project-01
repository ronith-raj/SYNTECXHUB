        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "# Load Iris dataset directly from Kaggle or UCI repository\n",
        "url = \"https://raw.githubusercontent.com/uiuc-cse/data-fa14/gh-pages/data/iris.csv\"\n",
        "df = pd.read_csv(url)\n",
        "\n",
        "# Convert to NumPy array\n",
        "data = df.iloc[:, :-1].values   # only numeric columns\n",
        "labels = df.iloc[:, -1].values  # species column\n",
        "\n",
        "print(\"Shape of data:\", data.shape)\n",
        "print(\"First 5 rows:\\n\", data[:5])"
      ],
