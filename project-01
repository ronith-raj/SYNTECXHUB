    {
      "cell_type": "code",
      "source": [
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Histogram of Sepal Length\n",
        "plt.hist(data[:,0], bins=20, color='skyblue', edgecolor='black')\n",
        "plt.title(\"Distribution of Sepal Length\")\n",
        "plt.xlabel(\"Sepal Length (cm)\")\n",
        "plt.ylabel(\"Frequency\")\n",
        "plt.show()\n",
        "\n",
        "# Compare feature means across species\n",
        "species = np.unique(labels)\n",
        "for i, sp in enumerate(species):\n",
        "    sp_data = data[labels == sp]\n",
        "    plt.bar(i, np.mean(sp_data[:,0]), label=sp)\n",
        "\n",
        "plt.xticks(range(len(species)), species)\n",
        "plt.ylabel(\"Mean Sepal Length\")\n",
        "plt.title(\"Mean Sepal Length by Species\")\n",
        "plt.legend()\n",
        "plt.show()"
